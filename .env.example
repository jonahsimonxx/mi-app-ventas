# Variables de entorno de la aplicación.
# Copia este archivo a ".env" y rellena los valores reales.

# --- API de El Toque (tasas TRMI) ---
# Token de acceso (Bearer). Solicítalo en https://eltoque.com
ELTOQUE_TOKEN=
# URL base de la API (normalmente no necesitas cambiarla).
ELTOQUE_BASE_URL=https://tasas.eltoque.com

# --- Base de datos PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=mi-app-ventas-data-base
