{
  "name": "mi-app-ventas",
  "version": "1.0.0",
  "description": "Aplicación de escritorio para registro de ventas, inventario y finanzas",
  "main": "dist/main/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "cross-env NODE_ENV=development tsc && electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && npm run dev:main\"",
    "build:renderer": "vite build",
    "build:main": "tsc",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron ."
  },
  "keywords": [],
  "author": "Jonathan",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.16.0",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "electron": "^41.5.0",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/cheerio": "^0.22.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^8.0.0"
  }
}
